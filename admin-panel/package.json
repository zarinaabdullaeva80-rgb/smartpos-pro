{
    "name": "smartpos-admin-panel",
    "version": "4.1.0",
    "description": "SmartPOS Pro — Панель администрирования",
    "author": "SmartPOS Team",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.smartpos.admin",
        "productName": "SmartPOS Admin Panel",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "main.js",
            "preload.js",
            "app/**/*",
            "build/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "SmartPOS Admin Panel"
        }
    },
    "devDependencies": {
        "electron": "^28.3.3",
        "electron-builder": "^24.13.3"
    },
    "dependencies": {
        "axios": "^1.7.0"
    }
}