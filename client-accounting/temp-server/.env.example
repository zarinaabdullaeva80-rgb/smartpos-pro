# ========================================
# SmartPOS Pro — Environment Configuration
# ========================================
# Version: 3.0.0
# Copy this file to .env and fill in your values

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Option 1: Connection string (Railway, Neon, Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Individual params (local dev fallback)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accounting_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=5000
SERVER_HOST=0.0.0.0
NODE_ENV=production
API_URL=http://localhost:5000

# ========================================
# SECURITY — JWT
# ========================================
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# SESSION
# ========================================
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ========================================
# REDIS CACHE (Optional but Recommended)
# ========================================
ENABLE_REDIS_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://localhost:6379

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SmartPOS Pro <noreply@smartpos.pro>"

# ========================================
# TELEGRAM BOT (Optional)
# ========================================
# Get token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ========================================
# 1C INTEGRATION (Optional)
# ========================================
C1_API_URL=http://localhost/accounting/hs/exchange
C1_USERNAME=admin
C1_PASSWORD=admin
C1_SYNC_ENABLED=false
C1_SYNC_INTERVAL=15

# ========================================
# GOOGLE SHEETS INTEGRATION (Optional)
# ========================================
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-credentials.json

# ========================================
# FILE UPLOADS
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ========================================
# ERROR TRACKING (Sentry — Optional)
# ========================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ========================================
# SSL/TLS (Production)
# ========================================
SSL_CERT_PATH=
SSL_KEY_PATH=

# ========================================
# BACKUP CONFIGURATION
# ========================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_2FA=true
ENABLE_REDIS_CACHE=false
ENABLE_EMAIL_CAMPAIGNS=true
ENABLE_TELEGRAM_BOT=false
ENABLE_1C_SYNC=false

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_DIR=./logs
DEBUG=false
DEBUG_SQL=false
VERBOSE_LOGGING=false
