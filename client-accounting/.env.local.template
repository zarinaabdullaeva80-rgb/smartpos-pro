# API Configuration for ngrok Remote Access
# После запуска ngrok, скопируйте URL из строки "Forwarding" и укажите здесь

# Замените на ваш реальный ngrok URL (например: https://abc-123-def.ngrok-free.app)
VITE_API_URL=https://YOUR_NGROK_URL_HERE/api
VITE_SOCKET_URL=https://YOUR_NGROK_URL_HERE

# Пример:
# VITE_API_URL=https://1234-567-890-123.ngrok-free.app/api
# VITE_SOCKET_URL=https://1234-567-890-123.ngrok-free.app

# Для локальной разработки (по умолчанию):
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
