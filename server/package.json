{
  "name": "1c-accounting-server",
  "version": "4.2.3",
  "description": "Modern accounting system with WMS, CRM, and 1C integration",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "mobile": "node serve-mobile.js",
    "dev": "nodemon src/index.js",
    "fix-schema": "node fix-schema.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node src/scripts/runMigrations.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "keywords": [
    "accounting",
    "1c",
    "wms",
    "crm",
    "pos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.37.0",
    "bcrypt": "^6.0.0",
    "bwip-js": "^4.8.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-slow-down": "^3.0.1",
    "express-validator": "^7.3.1",
    "googleapis": "^131.0.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.63.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.6.2",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^30.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/src/test/**/*.test.js"
    ],
    "transform": {}
  }
}